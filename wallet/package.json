{
    "name": "frostbit-wallet",
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "build": "node build.js",
        "dev": "node build.js --watch",
        "build:popup": "vite build",
        "dev:popup": "vite --port 5174",
        "proto": "node -e \"const p=require('protobufjs'); p.load('pb/data.proto', (e,r)=>{ if(e) throw e; require('fs').writeFileSync('lib/data_proto.json', JSON.stringify(r.toJSON())); console.log('done'); })\""
    },
    "dependencies": {
        "@noble/curves": "^1.9.1",
        "@noble/hashes": "^1.7.2",
        "@picocss/pico": "^2.0.6",
        "@scure/bip32": "^1.6.2",
        "@scure/bip39": "^1.5.4",
        "protobufjs": "^7.4.0",
        "vue": "^3.5.0"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.1.0",
        "@vitejs/plugin-vue": "^6.0.0",
        "esbuild": "^0.25.0",
        "tailwindcss": "^4.1.0",
        "typescript": "^5.5.0",
        "vite": "^7.0.0"
    }
}