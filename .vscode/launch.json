{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug main",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/main",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "showLog": false,
            "output": "${workspaceFolder}/.vscode/__debug_main.exe",
            "preLaunchTask": "Prepare debug binaries",
            "env": {
                "GOMEMLIMIT": "32GiB",
                "GOGC": "200"
            }
        },
        {
            "name": "Debug current file",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${fileDirname}",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "showLog": false,
            "output": "${workspaceFolder}/.vscode/__debug_current_file.exe",
            "preLaunchTask": "Prepare debug binaries"
        },
        {
            "name": "Debug current test",
            "type": "go",
            "request": "launch",
            "mode": "test",
            "program": "${fileDirname}",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "showLog": false,
            "output": "${workspaceFolder}/.vscode/__debug_current_test.exe",
            "preLaunchTask": "Prepare debug binaries"
        },
        {
            "name": "Attach to process",
            "type": "go",
            "request": "attach",
            "mode": "local",
            "showLog": false,
            "processId": 0
        },
        {
            "name": "Run print_files",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/print/print_files.go",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "showLog": false,
            "output": "${workspaceFolder}/.vscode/__debug_print_files.exe",
            "preLaunchTask": "Prepare debug binaries"
        },
        {
            "name": "Run explorer",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/explorer",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "showLog": false,
            "output": "${workspaceFolder}/.vscode/__debug_explorer.exe",
            "preLaunchTask": "Prepare explorer debug run",
            "args": [
                "--node-data-dir",
                "${workspaceFolder}/data/data_node_0"
            ]
        },
        {
            "name": "Run npm dev",
            "type": "node-terminal",
            "request": "launch",
            "command": "npm run dev",
            "cwd": "${workspaceFolder}/explorer"
        },
        {
            "cwd": "${workspaceFolder}",
            "name": "Run simulateMain/tes.go",
            "request": "launch",
            "program": "${workspaceFolder}/simulateMain/tes.go",
            "type": "go",
            "console": "internalConsole",
            "showLog": false,
            "output": "${workspaceFolder}/.vscode/__debug_simulate_tes.exe",
            "preLaunchTask": "Prepare debug binaries",
            "env": {
                "GOMEMLIMIT": "32GiB",
                "GOGC": "200"
            },
            "mode": "auto"
        }
    ]
}